# Normalize line endings for cross-platform Flutter development.
* text=auto

# Source & config — always LF in the repo
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.sh text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.jar binary
*.keystore binary
*.jks binary
